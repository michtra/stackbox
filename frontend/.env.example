# Client URL
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000

# Server URL
NEXT_PUBLIC_SERVER_URL=http://localhost:8000

# MapBox Token
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token

# AWS Configuration
NEXT_PUBLIC_AWS_REGION=your_aws_region

# AWS S3 Configuration
NEXT_PUBLIC_S3_BUCKET_NAME=your_s3_bucket_name

# Amazon Cognito / next-auth
NEXT_PUBLIC_COGNITO_DOMAIN=https://us-east-1XXXXXXXXX.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=your_cognito_app_client_id
COGNITO_CLIENT_SECRET=your_cognito_app_client_secret
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32