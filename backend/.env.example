# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET_NAME=stackbox-uploads
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Upload Configuration
PRESIGNED_URL_EXPIRATION=300

# Application Configuration
ENVIRONMENT=development

# Database Configuration
# Local docker (development):
DATABASE_URL=postgresql://stackbox_user:stackbox_password@localhost:5432/stackbox
# AWS RDS (production) — SSL is applied automatically for non-localhost connections:
# DATABASE_URL=postgresql://stackbox_user:password@your-rds-endpoint.rds.amazonaws.com:5432/stackbox
